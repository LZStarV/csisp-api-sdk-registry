  "components": {
    "schemas": {
      "ClientInfo": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "client_id": {
            "type": "string"
          },
          "name": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "default_redirect_uri": {
            "type": "string"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["openid", "profile", "email"]
            }
          }
        }
      },
      "GetAuthorizationRequestParams": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ticket"],
        "properties": {
          "ticket": {
            "type": "string"
          }
        }
      },
      "AuthorizationRequestInfo": {
        "type": "object",
        "additionalProperties": false,
        "required": ["client_id", "client_name", "scope", "redirect_uri", "state"],
        "properties": {
          "client_id": {
            "type": "string"
          },
          "client_name": {
            "type": "string"
          },
          "scope": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["openid", "profile", "email"]
            }
          },
          "redirect_uri": {
            "type": "string"
          },
          "state": {
            "type": "string"
          }
        }
      },
      "LoginInternalDto": {
        "type": "object",
        "additionalProperties": false,
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "minLength": 5,
            "maxLength": 256
          },
          "password": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          }
        }
      },
      "LoginResult": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stepUp"],
        "properties": {
          "stepUp": {
            "type": "string",
            "enum": ["PENDING_PASSWORD"]
          }
        }
      },
      "RegisterDto": {
        "type": "object",
        "additionalProperties": false,
        "required": ["email", "password", "student_id"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "minLength": 5,
            "maxLength": 256
          },
          "password": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "student_id": {
            "type": "string",
            "pattern": "^\\\\d{10,12}$"
          },
          "display_name": {
            "type": ["string", "null"],
            "minLength": 1,
            "maxLength": 128
          },
          "redirect_uri": {
            "type": ["string", "null"],
            "minLength": 1,
            "maxLength": 512
          }
        }
      },
      "RegisterResult": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ok", "next"],
        "properties": {
          "ok": {
            "type": "boolean",
            "enum": [true]
          },
          "next": {
            "type": "string",
            "enum": ["verify_email"]
          }
        }
      },
      "VerifySignupOtpDto": {
        "type": "object",
        "additionalProperties": false,
        "required": ["email", "token"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "minLength": 5,
            "maxLength": 256
          },
          "token": {
            "type": "string",
            "pattern": "^\\\\d{8}$"
          }
        }
      },
      "VerifiedResult": {
        "type": "object",
        "additionalProperties": false,
        "required": ["verified"],
        "properties": {
          "verified": {
            "type": "boolean",
            "enum": [true]
          }
        }
      },
      "ResendSignupOtpDto": {
        "type": "object",
        "additionalProperties": false,
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "minLength": 5,
            "maxLength": 256
          }
        }
      },
      "OkResult": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ok"],
        "properties": {
          "ok": {
            "type": "boolean",
            "enum": [true]
          }
        }
      },
      "VerifyOtpDto": {
        "type": "object",
        "additionalProperties": false,
        "required": ["token"],
        "properties": {
          "token": {
            "type": "string",
            "minLength": 4,
            "maxLength": 16
          }
        }
      },
