        "type": "object",
        "additionalProperties": false,
        "required": ["studentId", "newPassword", "resetToken"],
        "properties": {
          "studentId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "newPassword": {
            "type": "string",
            "minLength": 8,
            "maxLength": 64
          },
          "resetToken": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "reason": {
            "$ref": "#/components/schemas/ResetReason"
          }
        }
      },
      "ResetReason": {
        "type": "string",
        "enum": ["WeakPassword", "Compromised", "UserRequest", "Other"]
      },
      "AuthEnterRequest": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string"
          },
          "ticket": {
            "type": "string"
          },
          "redirectMode": {
            "type": "string"
          },
          "studentId": {
            "type": "string"
          }
        }
      },
      "AuthMfaMethodsResult": {
        "type": "object",
        "required": ["multifactor"],
        "properties": {
          "multifactor": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IMethod"
            }
          }
        }
      },
      "IMethod": {
        "type": "object",
        "required": ["type", "enabled"],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/MFAType"
          },
          "enabled": {
            "type": "boolean"
          },
          "extra": {
            "type": "string"
          }
        }
      },
      "AuthForgotInitRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "AuthForgotInitResult": {
        "type": "object",
        "required": ["student_id", "methods"],
        "properties": {
          "student_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "methods": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecoveryMethod"
            }
          }
        }
      },
      "RecoveryMethod": {
        "type": "object",
        "required": ["type", "enabled"],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/MFAType"
          },
          "enabled": {
            "type": "boolean"
          },
          "extra": {
            "type": "string"
          },
          "reason": {
            "$ref": "#/components/schemas/RecoveryUnavailableReason"
          }
        }
      },
      "RecoveryUnavailableReason": {
        "type": "integer",
        "enum": [0, 1, 2, 3, 4]
      },
      "AuthForgotChallengeRequest": {
        "type": "object",
        "required": ["type", "studentId"],
        "properties": {
          "type": {
            "type": "string"
          },
          "studentId": {
            "type": "string"
          }
        }
      },
      "AuthForgotVerifyRequest": {
        "type": "object",
        "required": ["type", "studentId", "code"],
        "properties": {
          "type": {
            "type": "string"
          },
          "studentId": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      },
      "AuthForgotVerifyResult": {
        "type": "object",
        "required": ["ok"],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "reset_token": {
            "type": "string"
          }
        }
      },
      "AuthSessionRequest": {
        "type": "object",
        "properties": {
          "logout": {
            "type": "boolean"
