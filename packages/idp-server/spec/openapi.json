              "code": {
                "type": "string"
              },
              "success": {
                "type": "boolean"
              },
              "message": {
                "type": "string"
              },
              "request_id": {
                "type": "string"
              },
              "access_denied_detail": {
                "type": "string"
              }
            }
          }
        }
      },
      "AuthNextStep": {
        "type": "integer",
        "enum": [0, 1, 2, 3]
      },
