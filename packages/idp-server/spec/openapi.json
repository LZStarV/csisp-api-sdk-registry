        "type": "object",
        "additionalProperties": false,
        "required": ["app_id", "redirect_uri"],
        "properties": {
          "app_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "redirect_uri": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          },
          "state": {
            "type": ["string", "null"],
            "minLength": 1,
            "maxLength": 256
          }
        }
      },
      "CreateExchangeCodeResult": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "redirect_uri"],
        "properties": {
          "code": {
            "type": "string"
          },
          "redirect_uri": {
            "type": "string"
          },
          "state": {
            "type": ["string", "null"]
          }
        }
      },
